{
  "name": "chess",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build --dotenv .env.production",
    "build:local": "nuxt build --dotenv .env.local",
    "dev": "nuxt dev --dotenv .env.local",
    "dev:lan": "nuxt dev --dotenv .env.local --host 0.0.0.0",
    "preview": "node --env-file=.env.production .output/server/index.mjs",
    "start": "node --env-file=.env.production .output/server/index.mjs",
    "start:local": "node --env-file=.env.local .output/server/index.mjs",
    "typecheck": "NUXT_BUILD_DIR=.nuxt-typecheck nuxt typecheck",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "element-plus": "^2.14.2",
    "mysql2": "^3.22.6",
    "nuxt": "^4.4.8",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@element-plus/nuxt": "^1.1.5",
    "less": "^4.6.7",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.6"
  }
}
